rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Client data — the app uses a custom hardcoded frontend login, so Firebase auth is null.
    match /clients/{doc=**}      { allow read, write: if true; }
    match /holdings/{doc=**}     { allow read, write: if true; }
    match /transactions/{doc=**} { allow read, write: if true; }

    // price_cache — public market data, open read/write
    // Safe: contains only NSE closing prices (publicly available data)
    // Written by sync script, read by dashboard
    match /price_cache/{doc=**}  { allow read, write: if true; }
  }
}
