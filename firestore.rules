rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Client data — authenticated users only
    match /clients/{doc=**}      { allow read, write: if request.auth != null; }
    match /holdings/{doc=**}     { allow read, write: if request.auth != null; }
    match /transactions/{doc=**} { allow read, write: if request.auth != null; }

    // price_cache — public market data, open read/write
    // Safe: contains only NSE closing prices (publicly available data)
    // Written by sync script, read by dashboard
    match /price_cache/{doc=**}  { allow read, write: if true; }
  }
}
